# ─────────────────────────────────────────────────────────────
#  AXIOM AVS Operator — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────
AXIOM_ENV=development          # development | testnet | mainnet
RUST_LOG=avs_operator=info     # Logging level
RUST_BACKTRACE=1               # Full backtraces on panic

# ── Chain RPC endpoints ───────────────────────────────────────
L3_RPC_URL=ws://127.0.0.1:8546                   # AXIOM L3 WebSocket RPC
L2_RPC_URL=wss://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Contract addresses ────────────────────────────────────────
# Get these after running: forge script script/DeployAVS.s.sol
TASK_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
SERVICE_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
WORLD_ADDRESS=0x0000000000000000000000000000000000000000

# ── Operator keys ─────────────────────────────────────────────
# SECURITY: In production use a KMS / HSM — never hardcode
# Dev: use Anvil account #0
OPERATOR_PRIVATE_KEY=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BLS_PRIVATE_KEY=0x01

# ── AI model artifacts ────────────────────────────────────────
MODEL_PATH=../ai-model/model.onnx
CIRCUIT_PATH=../circuits/ai_inference/circuit.ezkl
PROVING_KEY_PATH=../circuits/ai_inference/pk.key

# ── Worker settings ───────────────────────────────────────────
MAX_CONCURRENT_TASKS=4
DEADLINE_BUFFER_BLOCKS=5
MAX_TASK_AGE_MS=30000
PATHFINDING_MAX_NODES=10000

# ── Proof settings ────────────────────────────────────────────
PROOF_TIMEOUT_SECS=120
PROOF_RETRIES=2

# ── Submission settings ───────────────────────────────────────
SUBMIT_GAS_LIMIT=500000
MAX_GAS_GWEI=50
SUBMIT_RETRIES=3

# ── Misc ──────────────────────────────────────────────────────
DRY_RUN=false                  # true = compute but don't submit
POLL_INTERVAL_MS=500           # How often to check for new tasks
METRICS_PORT=9090              # Prometheus metrics port
